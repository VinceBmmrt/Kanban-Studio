{
  "tables": {
    "users": {
      "columns": {
        "id": { "type": "INTEGER", "primaryKey": true, "autoIncrement": true },
        "username": { "type": "TEXT", "notNull": true, "unique": true },
        "password_hash": { "type": "TEXT", "notNull": true }
      }
    },
    "boards": {
      "columns": {
        "id": { "type": "INTEGER", "primaryKey": true, "autoIncrement": true },
        "user_id": { "type": "INTEGER", "notNull": true, "references": "users.id" },
        "name": { "type": "TEXT", "notNull": true, "default": "My Board" }
      }
    },
    "columns": {
      "columns": {
        "id": { "type": "TEXT", "primaryKey": true },
        "board_id": { "type": "INTEGER", "notNull": true, "references": "boards.id" },
        "title": { "type": "TEXT", "notNull": true },
        "position": { "type": "INTEGER", "notNull": true }
      }
    },
    "cards": {
      "columns": {
        "id": { "type": "TEXT", "primaryKey": true },
        "column_id": { "type": "TEXT", "notNull": true, "references": "columns.id" },
        "title": { "type": "TEXT", "notNull": true },
        "details": { "type": "TEXT", "notNull": true, "default": "" },
        "position": { "type": "INTEGER", "notNull": true }
      }
    }
  }
}
